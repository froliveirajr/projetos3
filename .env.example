PORT=8081

# Supabase: Project Settings > Database > Connection string > JDBC
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.SEUPROJECTREF
SPRING_DATASOURCE_PASSWORD=sua-senha-do-banco
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Credenciais do administrador do sistema
APP_ADMIN_CNPJ=00.000.000/0001-00
APP_ADMIN_SENHA=troque-esta-senha

# Opcional: cria empresas de exemplo quando o banco estiver vazio
APP_SEED_DEMO_DATA=false
